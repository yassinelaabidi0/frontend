{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "npm",
      "script": "compile",
      "group": "build",
      "detail": "Compile TypeScript via esbuild (one-shot)"
    },
    {
      "label": "npm: watch",
      "type": "npm",
      "script": "watch",
      "group": "build",
      "isBackground": true,
      "detail": "Watch and recompile on file changes",
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^.*$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[esbuild\\] Watching",
          "endsPattern": "\\[esbuild\\] Build complete"
        }
      }
    }
  ]
}
